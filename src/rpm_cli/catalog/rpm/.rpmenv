# RPM Configuration
# Environment variables override these values (for pipeline integration)

# Repo Tool (fork with envsubst support)
REPO_URL=https://github.com/caylent-solutions/rpm-git-repo.git
REPO_REV=main

# Shared env vars for envsubst (resolved by 'repo envsubst' in remote.xml)
GITBASE=<YOUR_GIT_ORG_BASE_URL>
CLAUDE_MARKETPLACES_DIR=${HOME}/.claude-marketplaces

# Marketplace install toggle (set to true to enable Claude Code plugin lifecycle)
RPM_MARKETPLACE_INSTALL=<true|false>

# --- Sources ---
# Define one or more sources. Each source needs three variables:
#   RPM_SOURCE_<name>_URL      — Git URL of the manifest repository
#   RPM_SOURCE_<name>_REVISION — Branch, tag, or PEP 440 constraint
#   RPM_SOURCE_<name>_PATH     — Path to the entry-point manifest XML
#
# Example: single source (marketplace plugins only)
# RPM_SOURCE_plugins_URL=https://github.com/your-org/your-manifest-repo.git
# RPM_SOURCE_plugins_REVISION=main
# RPM_SOURCE_plugins_PATH=repo-specs/marketplace-manifest.xml
#
# Example: two sources (build packages + marketplace plugins)
# RPM_SOURCE_packages_URL=https://github.com/your-org/your-packages-repo.git
# RPM_SOURCE_packages_REVISION=refs/tags/>=1.0.0,<2.0.0
# RPM_SOURCE_packages_PATH=repo-specs/build/packages.xml
#
# RPM_SOURCE_plugins_URL=https://github.com/your-org/your-marketplace-repo.git
# RPM_SOURCE_plugins_REVISION=main
# RPM_SOURCE_plugins_PATH=repo-specs/marketplace-manifest.xml
